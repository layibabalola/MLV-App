.qtcreator

# Docs tree is the canonical documentation set; track it even if filenames
# happen to contain "build" (e.g. 10-build-windows.md).
!docs/
!docs/**

# Agent working state — profiling runs, ephemeral analysis, stashed artifacts.
# Durable findings go under .claude/ and are tracked; .claude-state/ is scratch.
.claude-state/

# Local nested agent worktrees are load-bearing but not repo content.
.claude/worktrees/

# Local property-test cache.
.hypothesis/

# Local agent prompt scratch.
CLAUDE_CODE_PROMPTS.md

# Per-machine Claude Code settings (permissions, local hooks). The shared
# .claude/settings.json (if it exists) is tracked; this one stays local.
.claude/settings.local.json

# Local bridge monitor/runtime breadcrumbs should live under bridge state or
# scratch; ignore accidental root-level drops.
monitor-*.runtime.json
peer-*.runtime.json
watcher.runtime.json
presence-*.runtime.json
.bridge-state/
bridge-root.json
MOVED_TO.json

# Python bytecode (e.g. tools/agent-bridge/)
__pycache__/
*.pyc
*.pyo

# Extracted local FFmpeg binary; release archives above remain tracked.
platform/qt/FFmpeg/ffmpeg.exe
