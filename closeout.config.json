      "ambiguous_merge_required",
      "active_locked_worktree",
      "unowned_dirty_triage"
    ]
  },
  "repoSweep": {
    "enabled": true,
    "mergeMode": "auto_clean",
    "pruneMergedLocalBranches": true,
    "pruneWorktrees": "clean_detached_only",
    "stashMode": "retain",
