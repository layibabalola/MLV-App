        "detached_dirty_preserve",
        "redundant_branch_prune",
        "explicit_protected_worktree_cleanup",
        "agent_conflict_remediation",
        "dirty_cluster_preservation",
        "stale_claim_remediation",
        "remediation_freeze_removal"
