{
  "_comment": "agent-bridge watcher config. The watcher is notification-only: use toast/log to alert, never consume messages from here. Prefer settings.json for runtime tuning.",
  "_auto_nudge_help": "Auto-nudge (targeted_sendkeys) is ON by default. To opt out of focus-stealing and compositor typing, add {\"wake_provider\": \"disabled\"} to settings.json. Valid values: targeted_sendkeys (default), disabled, app_server.",
  "toasts_enabled": true,
  "sessions": [
    {
      "_comment": "Claude private inbox - toast only; Claude Monitor/check_inbox consumes explicitly.",
      "agent": "claude",
      "kind": "private",
      "project": "mlv-app",
      "session_id_source": "active_session",
      "session_id": "YOUR-CLAUDE-SESSION-GUID",
      "inbox": "C:\\Users\\YOUR_USERNAME\\.agent-bridge\\state\\inbox-claude.jsonl",
      "on_message": "toast"
    },
    {
      "_comment": "Codex private inbox - toast + optional targeted wake. Use the managed argv template so strict foreground protection and explicit delivery-priority displacement are both visible.",
      "agent": "codex",
      "kind": "private",
      "project": "mlv-app",
      "session_id_source": "active_session",
      "session_id": "YOUR-CODEX-SESSION-GUID",
      "inbox": "C:\\Users\\YOUR_USERNAME\\.agent-bridge\\state\\inbox-codex.jsonl",
      "on_message": "toast",
      "on_message_command_template": [
        "powershell",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "C:\\path\\to\\wake_codex.ps1",
        "-Message",
        "Watcher says check bridge inbox",
        "-ThreadId",
        "{desktop_thread_id}",
        "-RestoreThreadId",
        "{restore_thread_id}",
        "-ExpectedProjectToken",
        "{project}",
        "-RunInnerWake",
        "-RequireThreadId",
        "-RequireConstantMessage",
        "-VerifyTargetTwice",
        "-VerifyTargetGapMilliseconds",
        "50",
        "-MaxPreSendRaceMilliseconds",
        "500",
        "-PostTypingVerify",
        "-WarnOnTitleMismatch",
        "-ProtectForegroundCodexThread",
        "-AllowForegroundCodexThreadDisplacement"
      ]
    },
    {
      "_comment": "Optional project rendezvous/control-plane watch.",
      "agent": "codex",
      "kind": "rendezvous",
      "project": "mlv-app",
      "session_id": "mlv-app",
      "inbox": "C:\\Users\\YOUR_USERNAME\\.agent-bridge\\state\\inbox-codex.jsonl",
      "on_message": "toast"
    }
  ]
}
